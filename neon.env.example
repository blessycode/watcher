# Neon PostgreSQL environment template for Watcher.
# Copy the pooled Neon connection string from Neon and paste it into Render as DATABASE_URL.
# Do not commit real credentials.

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/watcher?sslmode=require

# Recommended Neon settings:
# - Use a pooled connection string for Render web, worker, and beat.
# - Keep sslmode=require.
# - Create a clean production database before running Alembic migrations.
# - Run migrations from Render build command or manually:
#   alembic -c alembic.ini upgrade head
