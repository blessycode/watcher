# Upstash Redis environment template for Watcher.
# Copy the Redis connection URL from Upstash and paste it into Render as REDIS_URL.
# Do not commit real credentials.

REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:PORT

# Watcher uses Redis for:
# - Celery broker
# - Celery result backend
# - Scheduled monitor checks through Celery beat
#
# Use the same REDIS_URL on:
# - watcher-api Render web service
# - watcher-celery-worker Render background worker
# - watcher-celery-beat Render background worker
